rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles — created on first Google sign-in.
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // A user may create only their own profile, and only as a patient.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'patient';
      // A user may update their own profile but cannot change their role.
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == resource.data.role;
      allow update, delete: if isAdmin();
    }

    // Appointments — created/managed server-side via Admin SDK (bypasses rules).
    // Patients may read their own; admins may read/write all.
    match /appointments/{id} {
      allow read: if isSignedIn() && (resource.data.patientId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Appointment requests — created server-side via Admin SDK.
    // Patients may read their own requests; admins read/write all.
    match /appointmentRequests/{id} {
      allow read: if isSignedIn() && (resource.data.patientId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Contact submissions — created server-side. Admins read/update (mark as
    // read) and may delete to honour GDPR Art. 17 erasure requests.
    match /contactSubmissions/{id} {
      allow read, update, delete: if isAdmin();
      allow create: if false;
    }

    // Newsletter subscribers — created/updated server-side via the Admin SDK
    // (double opt-in). Admins may read and delete (erasure / list management);
    // clients can never write directly.
    match /newsletterSubscribers/{id} {
      allow read, delete: if isAdmin();
      allow create, update: if false;
    }

    // Availability config — read by the server; only admins write from the client.
    match /availability/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
